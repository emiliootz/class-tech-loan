
.dashboard-container {
  display: flex;
  min-height: calc(100vh - 100px); /* Adjust based on your navbar height */
}

.sidebar {
  width: 250px;
  background-color: #f7f7f7;
  border-right: 1px solid #ddd;
  padding: 20px;
}

.sidebar ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.sidebar ul li {
  margin-bottom: 15px;
}

.sidebar ul li a {
  text-decoration: none;
  color: #005a8b;
  font-weight: 600;
}

.dashboard-content {
  flex: 1;
  padding: 20px;
}

.chart {
  margin-top: 20px;
}
