<%- include('partials/head', { title: 'Dashboard', styles: ['dashboard.css'] }) %>
<%- include('partials/navbar', { cartCount, isLoggedIn, isAdmin, isStaff }) %>

<div class="container-fluid">
  <div class="row min-vh-100">
    <%- include('partials/sidebar', { activeLink: 'dashboard' }) %>

    <main class="col-md-9 col-lg-10 p-4">
      <h1 class="mb-4">Dashboard</h1>

      <div class="row">
        <div class="col-12 col-lg-4 mb-4">
          <div class="card shadow-sm text-center">
            <div class="card-body">
              <h5 class="card-title">Active Loans</h5>
              <p class="display-6 fw-bold text-primary"><%= activeLoans %></p>
            </div>
          </div>
        </div>
        <div class="col-12 col-lg-4 mb-4">
          <div class="card shadow-sm text-center">
            <div class="card-body">
              <h5 class="card-title">Total Users</h5>
              <p class="display-6 fw-bold text-success"><%= totalUsers %></p>
            </div>
          </div>
        </div>
        <div class="col-12 col-lg-4 mb-4">
          <div class="card shadow-sm text-center">
            <div class="card-body">
              <h5 class="card-title">Available Items</h5>
              <p class="display-6 fw-bold text-info"><%= availableItems %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="card shadow-sm mt-2">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h5 class="mb-0">Pending Pickups</h5>
          <a href="/loaned-items" class="btn btn-sm btn-outline-primary">View All</a>
        </div>
        <div class="card-body p-0">
          <% if (recentLoans.length === 0) { %>
          <p class="text-muted p-3 mb-0">No active loans.</p>
          <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Faculty</th>
                  <th>Item</th>
                  <th>Pickup Time</th>
                  <th>Return Time</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% recentLoans.forEach(function(loan) { %>
                <tr>
                  <td><%= loan.userId ? loan.userId.name : 'Unknown' %></td>
                  <td><%= loan.itemId ? loan.itemId.make + ' ' + loan.itemId.model : 'Unknown' %></td>
                  <td><%= loan.arrivalTime ? new Date(loan.arrivalTime).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) : '—' %></td>
                  <td><%= loan.returnTime ? new Date(loan.returnTime).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) : '—' %></td>
                  <td>
                    <form action="/return-item/<%= loan._id %>?_method=PUT" method="POST">
                      <button type="submit" class="btn btn-sm btn-success">Return</button>
                    </form>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>
      </div>
    </main>
  </div>
</div>

<%- include('partials/foot') %>
