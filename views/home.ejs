<%- include('partials/head', { title: 'UMass Boston Equipment Borrowing', styles: ['home.css'] }) %>
<%- include('partials/navbar', { cartCount, isLoggedIn, isAdmin, isStaff: locals.isStaff || false }) %>

<div class="hero hero--home">
  <div class="hero__media">
    <img
      src="/images/bg.png"
      alt=""
      class="hero__bg"
    />

    <div class="hero__content">
      <div class="hero__title">
        <span class="hero__title-line hero__title-line--left">Borrow Equipment</span>
        <span class="hero__title-line hero__title-line--right">at UMass Boston</span>
      </div>
    </div>
  </div>
</div>

<section class="category">
  <h1>Categories</h1>
  <a href="/" class="category-box<%= !activeCategory ? ' active' : '' %>">
    <div class="dark-overlay"></div>
    <h3>All</h3>
  </a>
  <% ['Video', 'Audio', 'Photo', 'Dongle'].forEach(function(cat) { %>
  <a
    href="/?category=<%= cat %>"
    class="category-box<%= activeCategory && activeCategory.toLowerCase() === cat.toLowerCase() ? ' active' : '' %>"
  >
    <div class="dark-overlay"></div>
    <h3><%= cat %></h3>
  </a>
  <% }); %>
</section>

<section class="available-items">
  <h1>Available Items</h1>

  <% if (items.length > 0) { %>
  <div class="container-fluid px-4">
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
      <% items.forEach(function(item) { %>
      <div class="col">
        <a href="/item/<%= item._id %>" class="text-decoration-none text-dark">
          <div class="card h-100 shadow-sm">
            <div class="d-flex justify-content-center align-items-center p-3" style="height: 200px;">
              <img src="<%= item.picture %>" alt="<%= item.make %> <%= item.model %>" class="img-fluid" style="max-height: 180px; object-fit: contain;" />
            </div>
            <div class="card-body text-center">
              <h5 class="card-title"><%= item.make %> <%= item.model %></h5>
              <% if (item.status === 'Available') { %>
              <form action="/add-to-cart/<%= item._id %>" method="POST">
                <button type="submit" class="btn btn-umb w-100">Add to Cart</button>
              </form>
              <% } else { %>
              <button class="btn btn-secondary w-100" disabled>Unavailable</button>
              <% } %>
            </div>
          </div>
        </a>
      </div>
      <% }); %>
    </div>
  </div>
  <% } else { %>
  <p>No items available at the moment.</p>
  <% } %>

  <% if (totalPages > 1) { %>
  <div class="pagination">
    <% if (currentPage > 1) { %>
    <a
      href="/?<%= activeCategory ? 'category=' + activeCategory + '&' : '' %>page=<%= currentPage - 1 %>"
      class="page-btn"
    >&laquo; Prev</a>
    <% } %>
    <% for (let p = 1; p <= totalPages; p++) { %>
    <a
      href="/?<%= activeCategory ? 'category=' + activeCategory + '&' : '' %>page=<%= p %>"
      class="page-btn<%= p === currentPage ? ' active' : '' %>"
    ><%= p %></a>
    <% } %>
    <% if (currentPage < totalPages) { %>
    <a
      href="/?<%= activeCategory ? 'category=' + activeCategory + '&' : '' %>page=<%= currentPage + 1 %>"
      class="page-btn"
    >Next &raquo;</a>
    <% } %>
  </div>
  <% } %>
</section>

<%- include('partials/foot') %>
