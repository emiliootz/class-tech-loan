<%- include('partials/head', { title: 'User Management', styles: ['users.css'] }) %>

<% if (!isLoggedIn || (!isAdmin && !isStaff)) { %>
<%- include('partials/navbar', { cartCount, isLoggedIn, isAdmin, isStaff }) %>
<div class="container py-5 text-center">
  <h1 class="text-danger">Access Denied</h1>
  <p>You do not have permission to view this page.</p>
</div>
<% } else { %>
<%- include('partials/navbar', { cartCount, isLoggedIn, isAdmin, isStaff }) %>

<div class="container-fluid">
  <div class="row min-vh-100">
    <%- include('partials/sidebar', { activeLink: 'users' }) %>

    <main class="col-md-9 col-lg-10 p-4">
      <h1 class="mb-4">User Management</h1>

      <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
          <thead class="custom-thead">
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Phone Number</th>
              <th>Role</th>
              <% if (isAdmin) { %><th>Actions</th><% } %>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(function(user) { %>
            <tr>
              <td><%= user.name %></td>
              <td><%= user.email %></td>
              <td><%= user.phone %></td>
              <td><%= user.role %></td>
              <% if (isAdmin) { %>
              <td>
                <a href="/users/<%= user._id %>/edit" class="btn btn-sm btn-outline-primary me-2">Edit</a>
                <form method="POST" action="/admin/users/<%= user._id %>?_method=DELETE" style="display: inline">
                  <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
              </td>
              <% } %>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </main>
  </div>
</div>
<% } %>

<%- include('partials/foot') %>
