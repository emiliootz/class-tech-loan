# Google OAuth credentials
# Create at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/callback

# MongoDB connection URLs
MONGO_URL_FACULTY_TECH_LENDING=mongodb://127.0.0.1:27017/faculty-tech-lending
MONGO_URL_PASSPORT_GOOGLE=mongodb://127.0.0.1:27017/passport-google

# Express session secret — use a long random string in production
SESSION_SECRET=change-me-to-a-long-random-string

# Port the app listens on
PORT=3000
